# Copy or rename this file to backend/.env before starting the backend.
# Example (PowerShell): Copy-Item .\backend\.env.example .\backend\.env

# Flask application secret key.
# Use a long random string in real deployments.
SECRET_KEY=your-flask-secret

# JWT signing key for login tokens.
# Use a long random string, ideally at least 32 characters.
JWT_SECRET_KEY=your-jwt-secret

# MySQL host. Use 127.0.0.1 for local development.
DB_HOST=127.0.0.1

# MySQL port. Default MySQL port is 3306.
DB_PORT=3306

# Database name. Create this database in MySQL before starting the backend.
DB_NAME=ann_search

# MySQL username. For local development this is often root.
DB_USER=root

# MySQL password for the DB_USER above.
DB_PASSWORD=your-mysql-password

# Optional: create the first administrator automatically on startup.
# If you do not want auto-creation, leave these three values empty.

# Admin login username shown on the frontend login page.
ADMIN_USERNAME=admin

# Admin email for the auto-created account.
ADMIN_EMAIL=admin@example.com

# Admin password used only when the admin account does not already exist.
# Changing this later will NOT automatically reset an existing admin password.
ADMIN_PASSWORD=change-this-password